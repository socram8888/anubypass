{
	"manifest_version": 3,
	"name": "Anubypass",
	"version": "1.1",
	"description": "Bypasses Anubis' JavaScript challenges by spoofing the browser's user agent.",
	"homepage_url": "https://orca.pet/",
	"icons": {
		"16": "logo/thumb_16.png",
		"128": "logo/thumb_128.png"
	},
	"permissions": [
		"declarativeNetRequest",
		"alarms"
	],
	"background": {
		"scripts": ["background.js"],
		"service_worker": "background.js"
	},
	"host_permissions": [
		"<all_urls>"
	]
}
